@model SurveyResultsViewModel

<div class="container w-50 mx-auto">
    <div class="mb-2 d-flex justify-content-between align-items-center">
        <h2>@Model.SurveyTitle</h2>
        <div>
            <div class="btn-group btn-group-sm">
                <input type="radio" class="btn-check" name="chartTypeRadio" id="barTypeRadio" value="bar" autocomplete="off" checked>
                <label class="btn btn-outline-primary" for="barTypeRadio">Bar Chart</label>

                <input type="radio" class="btn-check" name="chartTypeRadio" id="pieTypeRadio" value="pie" autocomplete="off">
                <label class="btn btn-outline-primary" for="pieTypeRadio">Pie Chart</label>
            </div>
        </div>
    </div>

    @foreach (var question in Model.Questions)
    {
        <div class="card mb-3">
            <div class="card-header">
                <strong>@question.QuestionText</strong>
            </div>

        @switch (question.Type) 
        {
            case QuestionType.SingleChoice:
            case QuestionType.MultipleChoice:
            case QuestionType.Dropdown:
            <text>
                <div class="card-body">
                    <table class="table table-bordered">
                        <thead>
                            <tr>
                                <th>Option</th>
                                <th>Votes</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var option in question.Options)
                            {
                                <tr>
                                    <td>@option.OptionText</td>
                                    <td>@option.Count</td>
                                </tr>
                            }
                        </tbody>
                    </table>

                    <canvas id="chart-@question.QuestionId" height="120"></canvas>
                </div>
            </text>
            break;

            case QuestionType.Rating5:
            case QuestionType.Rating10: 
            <text>
                <div class="card-body">
                    <div><span class="fw-bold">Average: </span> @question.RatingAverage / @(question.Type == QuestionType.Rating5 ? "5" : "10")</div>
                    <div><span class="fw-bold">Response: </span>@question.ResponseCount</div>
                </div>
            </text>
            break;
        }
        </div>
    }

    <a href="@Url.Action("Dashboard", "Survey")" class="btn btn-outline-info w-100">
        Back to Dashboard
    </a>
</div>

@section Scripts
{
    <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
    <script>
    @foreach (var question in Model.Questions)
    {
        <text>
            const ctx@(question.QuestionId) = document.getElementById('chart-@question.QuestionId');
    
            new Chart(ctx@(question.QuestionId), {
                type: 'bar',
                data: {
                    labels: [
                        @Html.Raw(string.Join(",",
                            question.Options.Select(o => $"'{o.OptionText}'")))
                ],
            datasets: [{
                label: 'Votes',
                data: [
                    @string.Join(",", question.Options.Select(o => o.Percentage))
                ]
            }]
        },
        options: {
            responsive: true,
            plugins: {
                legend: {
                    display: false
                }
            }
        }
    });
    </text>
    }
    </script>
}

