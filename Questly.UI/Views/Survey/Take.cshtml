@model TakeSurveyViewModel

<div class="container w-50 mx-auto">
    <h2>@Model.Title</h2>

    @if (!string.IsNullOrWhiteSpace(Model.Description))
    {
        <p class="text-muted">@Model.Description</p>
    }

    <hr />

    <form asp-action="Submit" asp-controller="Survey" method="post">

        <input asp-for="SurveyId" type="hidden" />

        @for (int i = 0; i < Model.Questions.Count; i++)
        {
            var question = Model.Questions[i];

            <div class="card mb-4">
                <div class="card-body">

                    <input asp-for="Questions[i].QuestionId" type="hidden" />
                    <input asp-for="Questions[i].Type" type="hidden" />

                    <h5>
                        @(i + 1). @question.Text

                        @if (question.IsRequired)
                        {
                            <span class="text-danger">*</span>
                        }
                    </h5>

                    @switch (question.Type)
                    {
                        case QuestionType.ShortText:
                            <input asp-for="Questions[i].AnswerText" class="form-control" />
                            break;

                        case QuestionType.LongText:
                            <textarea asp-for="Questions[i].AnswerText"
                                      class="form-control"
                                      rows="4"></textarea>
                            break;

                        case QuestionType.SingleChoice:
                            @foreach (var option in question.Options)
                            {
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="radio"
                                           asp-for="Questions[i].SelectedOptionId"
                                           value="@option.OptionId" />

                                    <label class="form-check-label">
                                        @option.Text
                                    </label>
                                </div>
                            }
                            break;

                        case QuestionType.MultipleChoice:
                            @foreach (var option in question.Options)
                            {
                                <div class="form-check">
                                    <input class="form-check-input"
                                           type="checkbox"
                                           name="Questions[@i].SelectedOptionIds"
                                           value="@option.OptionId" />

                                    <label class="form-check-label">
                                        @option.Text
                                    </label>
                                </div>
                            }
                            break;

                        case QuestionType.Dropdown:
                            <select asp-for="Questions[i].SelectedOptionId"
                                    class="form-select">

                                <option value="">-- Select --</option>

                                @foreach (var option in question.Options)
                                {
                                    <option value="@option.OptionId">
                                        @option.Text
                                    </option>
                                }

                            </select>
                            break;
                    }

                </div>
            </div>
        }

        <div class="d-flex gap-2">
            <button type="submit" class="btn btn-primary w-50">
                Submit Survey
            </button>
            
            <a href="@Url.Action("Index", "Survey")" class="btn btn-outline-danger w-50">
                Cancel
            </a>
        </div>

    </form>
</div>

