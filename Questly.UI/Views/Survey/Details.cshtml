@model GetSurveyViewModel

<div class="container w-50 mx-auto">
    <h1 class="mb-4">Survey Details</h1>
    <ul class="list-group mb-4">
        <li class="list-group-item"><span class="fw-bold">Title: </span>@Model.Title</li>
        <li class="list-group-item"><span class="fw-bold">Id: </span>@Model.Id</li>
        <li class="list-group-item"><span class="fw-bold">Creation Date and Time: </span>@Model.CreatedAt</li>
        <li class="list-group-item"><span class="fw-bold">Description: </span>@Model.Description</li>
    </ul>

    @if (!Model.Questions.Any())
    {
        <div class="alert alert-info">
            No questions have been added yet.
        </div>
    }
    else
    {
        var questions = Model.Questions.ToList();
        <div id="questionList">
            @for (int i = 0; i < questions.Count; ++i)
            {
                <div class="card mb-3" data-id="@questions[i].Id">
                    <div class="card-header d-flex">
                        <span class="me-2">☰</span>
                        <strong>@(i + 1). @questions[i].Text</strong>

                        @if (questions[i].IsRequired)
                        {
                            <span class="text-danger">*</span>
                        }

                        <div class="ms-auto">
                            <a href="@Url.Action("Edit", "Question", new { id = questions[i].Id })" class="btn btn-sm btn-warning text-white">Ed</a>
                            <a href="@Url.Action("Delete", "Question", new { id = questions[i].Id, surveyId = Model.Id })" class="btn btn-sm btn-danger">Del</a>
                        </div>
                    </div>

                    <div class="card-body">

                        @if (questions[i].Type == QuestionType.SingleChoice)
                        {
                            @if (questions[i].Options.Any())
                            {
                                @foreach (var option in questions[i].Options)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Q@(i + 1)_Opt" id="Q@(i + 1)_Opt@(option.Id)">
                                        <label class="form-check-label" for="Q@(i + 1)_Opt@(option.Id)">@option.Text</label>
                                    </div>
                                }
                            }
                        }

                        @if (questions[i].Type == QuestionType.MultipleChoice)
                        {
                            @if (questions[i].Options.Any())
                            {
                                @foreach (var option in questions[i].Options)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="Q@(i + 1)_Opt@(option.Id)" readonly>
                                        <label class="form-check-label" for="Q@(i + 1)_Opt@(option.Id)">@option.Text</label>
                                    </div>
                                }
                            }
                        }

                        @if (questions[i].Type == QuestionType.Dropdown)
                        {
                            @if (questions[i].Options.Any())
                            {
                                <select class="form-select">
                                    <option value="0" selected>-- Choose --</option>
                                    @foreach (var option in questions[i].Options)
                                    {
                                        <option value="@option.Id">@option.Text</option>
                                    }
                                </select>
                            }
                        }

                    </div>

                </div>
            }
        </div>
    }

    <div class="d-flex gap-2">
        <a href="@Url.Action("Create", "Question", new { surveyId = Model.Id })" class="btn btn-primary w-50">Add Question</a>
        <a asp-action="Index" class="btn btn-outline-info w-50">Back to My Surveys</a>
    </div>
</div>

@section Scripts {
    <script>
        $("#questionList").sortable({

            update: function () {

                var ids = [];

                $("#questionList .card").each(function () {
                    ids.push($(this).data("id"));
                });

                $.ajax({
                    url: "/Question/Reorder",
                    type: "POST",
                    traditional: true,
                    data: {
                        surveyId: @(Model.Id),
                        questionIds: ids
                    }
                });

            }

        });
    </script>
}

