@model GetSurveyViewModel

<div class="container w-50 mx-auto">
    <div class="mb-4 d-flex justify-content-between align-items-start">
        <div>
            <h1>Survey Details</h1>
            
            <p class="p-2 text-bg-danger rounded-2 fw-bold @(Model.IsOpen ? "d-none" : "")"
               style="font-size: 14px;">
                 This survey is currently closed.
            </p>
        </div>

        <div>
            <div class="d-flex gap-1 justify-content-end mb-3">
                <form asp-action="Clone"
                      asp-controller="Survey"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="d-inline">

                    <button class="btn btn-sm text-white" style="background-color: var(--bs-purple);">
                        Clone
                    </button>
                </form>

                <form asp-action="@(Model.IsPublished ? "Unpublish" : "Publish")"
                      asp-controller="Survey"
                      asp-route-id="@Model.Id"
                      method="post"
                      class="d-inline">

                    <button class="btn btn-sm @(Model.IsPublished ? "btn-danger" : "btn-success")">
                        @(Model.IsPublished ? "Unpublish" : "Publish")
                    </button>
                </form>
            </div>
            <div class="align-self-end">
                <form asp-action="SetExpiration" method="post">
                    <input type="hidden" name="id" value="@Model.Id" />

                    <input id="closedAt"
                           type="datetime-local"
                           name="closedAt"
                           value="@(Model.ClosedAt?.ToString("yyyy-MM-ddTHH:mm"))"
                           class="form-control form-control-sm mb-1" />

                    <button class="btn btn-sm btn-secondary">
                        Save Expiration
                    </button>
                    <button type="submit" class="btn btn-sm btn-outline-secondary"
                            onclick="document.getElementById('closedAt').value='';">
                        Remove Expiration
                    </button>
                </form>
            </div>
        </div>
        
    </div>

    @* PublicId Section *@
    <div class="card my-2">
        <div class="card-header">
            Public Survey Link
        </div>

        <div class="card-body">

            <div class="input-group">

                <input id="publicLink"
                       class="form-control"
                       style="font-size: 12.5px; font-weight: 600; color: rgba(0, 0, 0, .8);"
                       readonly
                       value="@Url.Action("Public", "Survey", new { publicId = Model.PublicId }, Context.Request.Scheme)" />

                <button id="copyLink"
                        type="button"
                        class="btn btn-outline-secondary">
                    Copy
                </button>

            </div>

        </div>
    </div>

    <script>
        document.getElementById("copyLink").addEventListener("click", function () {

            navigator.clipboard.writeText(
                document.getElementById("publicLink").value);

            alert("Link copied.");
        });
    </script>

    <ul class="list-group mb-4">
        <li class="list-group-item"><span class="fw-bold">Title: </span>@Model.Title</li>
        <li class="list-group-item"><span class="fw-bold">Id: </span>@Model.Id</li>
        <li class="list-group-item"><span class="fw-bold">Creation Date and Time: </span>@Model.CreatedAt</li>
        <li class="list-group-item"><span class="fw-bold">Description: </span>@Model.Description</li>
    </ul>

    @if (!Model.Questions.Any())
    {
        <div class="alert alert-info">
            No questions have been added yet.
        </div>
    }
    else
    {
        var questions = Model.Questions.ToList();
        <div id="questionList">
            @for (int i = 0; i < questions.Count; ++i)
            {
                <div class="card mb-3" data-id="@questions[i].Id">
                    <div class="card-header d-flex">
                        <span class="me-2">☰</span>
                        <strong>@(i + 1). @questions[i].Text</strong>

                        @if (questions[i].IsRequired)
                        {
                            <span class="text-danger">*</span>
                        }

                        <div class="ms-auto">
                            <a href="@Url.Action("Edit", "Question", new { id = questions[i].Id })" class="btn btn-sm btn-warning text-white">Ed</a>
                            <a href="@Url.Action("Delete", "Question", new { id = questions[i].Id, surveyId = Model.Id })" class="btn btn-sm btn-danger">Del</a>
                        </div>
                    </div>

                    <div class="card-body">

                        @if (questions[i].Type == QuestionType.SingleChoice)
                        {
                            @if (questions[i].Options.Any())
                            {
                                @foreach (var option in questions[i].Options)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="Q@(i + 1)_Opt" id="Q@(i + 1)_Opt@(option.Id)">
                                        <label class="form-check-label" for="Q@(i + 1)_Opt@(option.Id)">@option.Text</label>
                                    </div>
                                }
                            }
                        }

                        @if (questions[i].Type == QuestionType.MultipleChoice)
                        {
                            @if (questions[i].Options.Any())
                            {
                                @foreach (var option in questions[i].Options)
                                {
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="Q@(i + 1)_Opt@(option.Id)" readonly>
                                        <label class="form-check-label" for="Q@(i + 1)_Opt@(option.Id)">@option.Text</label>
                                    </div>
                                }
                            }
                        }

                        @if (questions[i].Type == QuestionType.Dropdown)
                        {
                            @if (questions[i].Options.Any())
                            {
                                <select class="form-select">
                                    <option value="0" selected>-- Choose --</option>
                                    @foreach (var option in questions[i].Options)
                                    {
                                        <option value="@option.Id">@option.Text</option>
                                    }
                                </select>
                            }
                        }

                    </div>

                </div>
            }
        </div>
    }

    <div class="d-flex gap-2">
        <a href="@Url.Action("Create", "Question", new { surveyId = Model.Id })" class="btn btn-primary w-50">Add Question</a>
        <a asp-action="Dashboard" class="btn btn-outline-info w-50">Back to My Surveys</a>
    </div>
</div>

@section Scripts {
    <script>
        $("#questionList").sortable({

            update: function () {

                var ids = [];

                $("#questionList .card").each(function () {
                    ids.push($(this).data("id"));
                });

                $.ajax({
                    url: "/Question/Reorder",
                    type: "POST",
                    traditional: true,
                    data: {
                        surveyId: @(Model.Id),
                        questionIds: ids
                    }
                });

            }

        });
    </script>
}

